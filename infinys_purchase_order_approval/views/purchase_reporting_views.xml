<odoo>
  <data>

    <!-- ============================================================
         DEDICATED LIST VIEW — HEAD SUPPLIER APPROVAL DASHBOARD
         Shows: PO name, partner, amount, current approvers, state
    ============================================================ -->
    <record id="view_po_list_head_supplier_approval" model="ir.ui.view">
      <field name="name">purchase.order.list.head.supplier.approval</field>
      <field name="model">purchase.order</field>
      <field name="arch" type="xml">
        <list string="Head Supplier Approvals" default_order="date_order desc"
              decoration-warning="state == 'to approve'">
          <field name="name" string="Order"/>
          <field name="partner_id" string="Vendor / Supplier"/>
          <field name="date_order" string="Order Date"/>
          <field name="amount_total" string="Total Amount" sum="Total"/>
          <field name="currency_id" column_invisible="1"/>
          <field name="current_approver_ids" widget="many2many_tags"
                 string="Waiting Approval From" optional="show"/>
          <field name="current_approval_type" string="Approval Type" optional="show"/>
          <field name="state" widget="badge"
                 decoration-warning="state == 'to approve'"
                 decoration-success="state == 'purchase'"
                 decoration-muted="state == 'cancel'"/>
        </list>
      </field>
    </record>

    <!-- ============================================================
         DEDICATED LIST VIEW — PROCUREMENT MANAGER APPROVAL DASHBOARD
         Shows: PO name, partner, amount, type, who is waiting, state
    ============================================================ -->
    <record id="view_po_list_procurement_manager_approval" model="ir.ui.view">
      <field name="name">purchase.order.list.procurement.manager.approval</field>
      <field name="model">purchase.order</field>
      <field name="arch" type="xml">
        <list string="All Pending Approvals" default_order="date_order desc"
              decoration-warning="state == 'to approve'">
          <field name="name" string="Order"/>
          <field name="partner_id" string="Vendor / Supplier"/>
          <field name="date_order" string="Order Date"/>
          <field name="amount_total" string="Total Amount" sum="Total"/>
          <field name="currency_id" column_invisible="1"/>
          <field name="current_approval_type" string="Approval Type"/>
          <field name="current_approver_ids" widget="many2many_tags"
                 string="Waiting Approval From"/>
          <field name="state" widget="badge"
                 decoration-warning="state == 'to approve'"
                 decoration-success="state == 'purchase'"
                 decoration-muted="state == 'cancel'"/>
        </list>
      </field>
    </record>

    <!-- ============================================================
         DEDICATED LIST VIEW — VENDOR APPROVAL DASHBOARD
         Shows: PO name, partner, amount, current approvers, state
    ============================================================ -->
    <record id="view_po_list_vendor_approval" model="ir.ui.view">
      <field name="name">purchase.order.list.vendor.approval</field>
      <field name="model">purchase.order</field>
      <field name="arch" type="xml">
        <list string="Vendor Approvals" default_order="date_order desc"
              decoration-warning="state == 'to approve'">
          <field name="name" string="Order"/>
          <field name="partner_id" string="Vendor / Supplier"/>
          <field name="date_order" string="Order Date"/>
          <field name="amount_total" string="Total Amount" sum="Total"/>
          <field name="currency_id" column_invisible="1"/>
          <field name="current_approver_ids" widget="many2many_tags"
                 string="Waiting Approval From" optional="show"/>
          <field name="current_approval_type" string="Approval Type" optional="show"/>
          <field name="state" widget="badge"
                 decoration-warning="state == 'to approve'"
                 decoration-success="state == 'purchase'"
                 decoration-muted="state == 'cancel'"/>
        </list>
      </field>
    </record>

    <!-- ============================================================
         ACTION — HEAD SUPPLIER APPROVAL DASHBOARD
         Domain: POs in 'to approve' where the logged-in user is the
         CURRENT approver (via stored field) AND type = 'supplier'.
         Uses current_approver_ids (stored) → no SQL-join ambiguity.
    ============================================================ -->
    <record id="action_head_supplier_approval_dashboard" model="ir.actions.act_window">
      <field name="name">Head Supplier Approvals</field>
      <field name="res_model">purchase.order</field>
      <field name="view_mode">list,form</field>
      <field name="views" eval="[
        (ref('view_po_list_head_supplier_approval'), 'list'),
        (False, 'form'),
      ]"/>
      <field name="domain">[
        ('state', '=', 'to approve'),
        ('current_approver_ids', 'in', [uid]),
        ('current_approval_type', '=', 'supplier'),
      ]</field>
      <field name="context">{'create': False}</field>
      <field name="target">current</field>
    </record>

    <!-- ============================================================
         ACTION — PROCUREMENT MANAGER APPROVAL DASHBOARD
         Domain: ALL POs in 'to approve' state — the manager has
         oversight over every pending approval regardless of type.
    ============================================================ -->
    <record id="action_procurement_manager_approval_dashboard" model="ir.actions.act_window">
      <field name="name">Procurement Manager Approvals</field>
      <field name="res_model">purchase.order</field>
      <field name="view_mode">list,form</field>
      <field name="views" eval="[
        (ref('view_po_list_procurement_manager_approval'), 'list'),
        (False, 'form'),
      ]"/>
      <field name="domain">[('state', '=', 'to approve')]</field>
      <field name="context">{'create': False}</field>
      <field name="target">current</field>
    </record>

    <!-- ============================================================
         ACTION — VENDOR APPROVAL DASHBOARD
         Domain: POs in 'to approve' where the logged-in user is the
         CURRENT approver (via stored field) AND type = 'vendor'.
    ============================================================ -->
    <record id="action_vendor_approval_dashboard" model="ir.actions.act_window">
      <field name="name">Vendor Approvals</field>
      <field name="res_model">purchase.order</field>
      <field name="view_mode">list,form</field>
      <field name="views" eval="[
        (ref('view_po_list_vendor_approval'), 'list'),
        (False, 'form'),
      ]"/>
      <field name="domain">[
        ('state', '=', 'to approve'),
        ('current_approver_ids', 'in', [uid]),
        ('current_approval_type', '=', 'vendor'),
      ]</field>
      <field name="context">{'create': False}</field>
      <field name="target">current</field>
    </record>

    <!-- ============================================================
         ACTION — MY APPROVALS (personal view: pending + history)
         Fixed domain: uses current_approver_ids (stored) instead of
         the old chained join that caused all-same-data bug.
    ============================================================ -->
    <record id="action_purchase_order_my_approval" model="ir.actions.act_window">
      <field name="name">My Approvals</field>
      <field name="res_model">purchase.order</field>
      <field name="view_mode">list,form</field>
      <field name="domain">[
        '|',
          '&amp;',
            ('state', '=', 'to approve'),
            ('current_approver_ids', 'in', [uid]),
          '|',
            ('approval_line_ids.approved_by_user_id', '=', uid),
            ('approval_line_ids.rejected_by_user_id', '=', uid),
      ]</field>
      <field name="context">{'create': False, 'search_default_my_pending_approvals': 1}</field>
      <field name="target">current</field>
    </record>

    <!-- ============================================================
         SEARCH FILTERS — extend the standard PO search view
    ============================================================ -->
    <record id="view_purchase_order_filter_inherit_approval" model="ir.ui.view">
      <field name="name">purchase.order.select.inherit.approval</field>
      <field name="model">purchase.order</field>
      <field name="inherit_id" ref="purchase.view_purchase_order_filter"/>
      <field name="arch" type="xml">
        <xpath expr="//filter[@name='my_purchases']" position="after">
          <separator/>
          <!-- Uses current_approver_ids (stored) — no join ambiguity -->
          <filter string="Pending My Approval" name="my_pending_approvals"
                  domain="[('state', '=', 'to approve'), ('current_approver_ids', 'in', [uid])]"/>
          <filter string="Pending Supplier Approval" name="pending_supplier_approvals"
                  domain="[('state', '=', 'to approve'), ('current_approval_type', '=', 'supplier')]"/>
          <filter string="Pending Vendor Approval" name="pending_vendor_approvals"
                  domain="[('state', '=', 'to approve'), ('current_approval_type', '=', 'vendor')]"/>
          <filter string="My Approval History" name="my_approval_history"
                  domain="['|', ('approval_line_ids.approved_by_user_id', '=', uid),
                                ('approval_line_ids.rejected_by_user_id', '=', uid)]"/>
        </xpath>
      </field>
    </record>

    <!-- ============================================================
         MENU ITEMS
    ============================================================ -->

    <!-- Parent sub-menu grouping all approval dashboards -->
    <menuitem
      id="menu_purchase_approvals_root"
      name="Approvals"
      parent="purchase.purchase_report_main"
      sequence="90"/>

    <!-- Head Supplier Approvals: only POs requiring supplier-type approval
         where the logged-in user is the active approver -->
    <menuitem
      id="menu_head_supplier_approval"
      name="Head Supplier Approvals"
      parent="menu_purchase_approvals_root"
      action="action_head_supplier_approval_dashboard"
      sequence="10"/>

    <!-- Procurement Manager Approvals: all pending POs regardless of type -->
    <menuitem
      id="menu_procurement_manager_approval"
      name="Procurement Manager Approvals"
      parent="menu_purchase_approvals_root"
      action="action_procurement_manager_approval_dashboard"
      sequence="20"/>

    <!-- Vendor Approvals: only POs requiring vendor-type approval
         where the logged-in user is the active approver -->
    <menuitem
      id="menu_vendor_approval"
      name="Vendor Approvals"
      parent="menu_purchase_approvals_root"
      action="action_vendor_approval_dashboard"
      sequence="30"/>

    <!-- My Approvals: personal combined view (pending + history) -->
    <menuitem
      id="menu_purchase_my_approval"
      name="My Approvals"
      parent="menu_purchase_approvals_root"
      action="action_purchase_order_my_approval"
      sequence="40"/>

  </data>
</odoo>
