<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_invoice_document_tts">
        <t t-set="bank_acc" t-value="o.company_id.bank_ids[:1]"/>
        <t t-set="ship" t-value="o.partner_shipping_id or o.partner_id"/>

        <div style="font-family:Arial,sans-serif; font-size:11px; color:#000; line-height:1.4;">

            <!-- TITLE -->
            <div style="text-align:center; font-size:14px; font-weight:bold; text-decoration:underline; margin-bottom:6px;">
                Tax Invoice
            </div>

            <!-- HEADER -->
            <table style="width:100%; border-collapse:collapse; border:1px solid #000; border-bottom:none;">
                <tr>
                    <td style="width:55%; vertical-align:top; border-right:1px solid #000; padding:0;">
                        <table style="width:100%; border-collapse:collapse;">
                            <tr>
                                <td style="padding:8px 8px; border-bottom:1px solid #000; vertical-align:top;">
                                    <strong style="font-size:12px;"><t t-out="o.company_id.name"/></strong><br/>
                                    <t t-out="o.company_id.street or ''"/><br/>
                                    <t t-if="o.company_id.street2"><t t-out="o.company_id.street2"/><br/></t>
                                    <t t-out="o.company_id.city or ''"/>, <t t-out="o.company_id.state_id.name or ''"/> - <t t-out="o.company_id.zip or ''"/>, <t t-out="o.company_id.country_id.name or ''"/><br/>
                                    <strong>GSTIN/UIN:</strong> <t t-out="o.company_id.vat or ''"/><br/>
                                    <strong>State Name :</strong> <t t-out="o.company_id.state_id.name or ''"/>, <strong>Code :</strong> <t t-out="o.company_id.state_id.l10n_in_tin or o.company_id.state_id.code or ''"/><br/>
                                    <strong>Contact :</strong> <t t-out="o.company_id.phone or ''"/><br/>
                                    <strong>E-Mail :</strong> <t t-out="o.company_id.email or ''"/>
                                </td>
                            </tr>
                            <tr>
                                <td style="padding:8px 8px; border-bottom:1px solid #000; vertical-align:top;">
                                    <span style="font-size:10px;">Consignee (Ship to)</span><br/>
                                    <strong><t t-out="ship.name"/></strong><br/>
                                    <t t-out="ship.street or ''"/><br/>
                                    <t t-if="ship.street2"><t t-out="ship.street2"/><br/></t>
                                    <t t-out="ship.city or ''"/>, <t t-out="ship.state_id.name or ''"/> - <t t-out="ship.zip or ''"/>, <t t-out="ship.country_id.name or ''"/><br/>
                                    <strong>GSTIN/UIN</strong>&#160;&#160;: <t t-out="ship.vat or ''"/><br/>
                                    <strong>PAN/IT No</strong>&#160;&#160;:
                                    <br/>
                                    <strong>State Name</strong>&#160;: <t t-out="ship.state_id.name or ''"/>, <strong>Code :</strong> <t t-out="ship.state_id.l10n_in_tin or ship.state_id.code or ''"/>
                                </td>
                            </tr>
                            <tr>
                                <td style="padding:8px 8px; vertical-align:top;">
                                    <span style="font-size:10px;">Buyer (Bill to)</span><br/>
                                    <strong><t t-out="o.partner_id.name"/></strong><br/>
                                    <t t-out="o.partner_id.street or ''"/><br/>
                                    <t t-if="o.partner_id.street2"><t t-out="o.partner_id.street2"/><br/></t>
                                    <t t-out="o.partner_id.city or ''"/>, <t t-out="o.partner_id.state_id.name or ''"/> - <t t-out="o.partner_id.zip or ''"/>, <t t-out="o.partner_id.country_id.name or ''"/><br/>
                                    <strong>GSTIN/UIN</strong>&#160;&#160;: <t t-out="o.partner_id.vat or ''"/><br/>
                                    <strong>PAN/IT No</strong>&#160;&#160;:
                                    <br/>
                                    <strong>State Name</strong>&#160;: <t t-out="o.partner_id.state_id.name or ''"/>, <strong>Code :</strong> <t t-out="o.partner_id.state_id.l10n_in_tin or o.partner_id.state_id.code or ''"/>
                                </td>
                            </tr>
                        </table>
                    </td>
                    <td style="width:45%; vertical-align:top; padding:0;">
                        <table style="width:100%; border-collapse:collapse;">
                            <tr>
                                <td style="padding:6px 6px; border-bottom:1px solid #000; border-right:1px solid #000; width:50%;">
                                    Invoice No.<br/>
                                    <strong><t t-out="o.name"/></strong>
                                </td>
                                <td style="padding:6px 6px; border-bottom:1px solid #000; width:50%;">
                                    Dated<br/>
                                    <strong>
                                        <span t-field="o.invoice_date" t-options='{"widget":"date","format":"d-MMM-yy"}'/>
                                    </strong>
                                </td>
                            </tr>
                            <tr>
                                <td style="padding:6px 6px; border-bottom:1px solid #000; border-right:1px solid #000;">
                                    Delivery Note<br/>&#160;
                                </td>
                                <td style="padding:6px 6px; border-bottom:1px solid #000;">
                                    Mode/Terms of Payment
                                    <br/>
                                    <strong>
                                        <t t-set="payment_methods"
                                           t-value="o.matched_payment_ids.mapped('payment_method_line_id.name')"/>
                                        <t t-out="', '.join([m for m in payment_methods if m]) or (o.invoice_payment_term_id.name or '')"/>
                                    </strong>
                                </td>
                            </tr>
                            <tr>
                                <td style="padding:6px 6px; border-bottom:1px solid #000; border-right:1px solid #000;">
                                    Reference No. &amp; Date.<br/>
                                    <strong>
                                        <t t-out="o.name"/> dt.
                                        <span t-field="o.invoice_date" t-options='{"widget":"date","format":"d-MMM-yy"}'/>
                                    </strong>
                                </td>
                                <td style="padding:6px 6px; border-bottom:1px solid #000;">
                                    Other References<br/>&#160;
                                </td>
                            </tr>
                            <tr>
                                <td style="padding:6px 6px; border-bottom:1px solid #000; border-right:1px solid #000;">
                                    Buyer's Order No.<br/>&#160;
                                </td>
                                <td style="padding:6px 6px; border-bottom:1px solid #000;">
                                    Dated<br/>&#160;
                                </td>
                            </tr>
                            <tr>
                                <td style="padding:6px 6px; border-bottom:1px solid #000; border-right:1px solid #000;">
                                    Dispatch Doc No.<br/>&#160;
                                </td>
                                <td style="padding:6px 6px; border-bottom:1px solid #000;">
                                    Delivery Note Date<br/>&#160;
                                </td>
                            </tr>
                            <tr>
                                <td style="padding:6px 6px; border-bottom:1px solid #000; border-right:1px solid #000;">
                                    Dispatched Through<br/>&#160;
                                </td>
                                <td style="padding:6px 6px; border-bottom:1px solid #000;">
                                    Destination<br/>&#160;
                                </td>
                            </tr>
                            <tr>
                                <td colspan="2" style="padding:6px 6px; vertical-align:top; height:96px;">
                                    Terms of Delivery
                                </td>
                            </tr>
                        </table>
                    </td>
                </tr>
            </table>

            <!-- Pre-compute shared values used by both tables (Odoo 19) -->
            <t t-set="product_lines" t-value="o.invoice_line_ids.filtered(lambda l: l.display_type == 'product')"/>
            <t t-set="total_cgst" t-value="sum(o.line_ids.filtered(lambda l: l.tax_line_id and 'CGST' in (l.tax_line_id.name or '').upper()).mapped('balance')) or (o.amount_tax / 2.0)"/>
            <t t-set="total_sgst" t-value="sum(o.line_ids.filtered(lambda l: l.tax_line_id and ('SGST' in (l.tax_line_id.name or '').upper() or 'UTGST' in (l.tax_line_id.name or '').upper())).mapped('balance')) or (o.amount_tax / 2.0)"/>
            <t t-set="first_taxed_line" t-value="product_lines.filtered(lambda l: l.tax_ids)[:1]"/>
            <t t-set="tax_label" t-value="', '.join(first_taxed_line.tax_ids.mapped('name')) if first_taxed_line else 'Local Sales'"/>
            <t t-set="round_off" t-value="o.amount_total - o.amount_untaxed - o.amount_tax"/>
            <t t-set="filled_lines" t-value="len(product_lines)"/>

            <!-- PRODUCTS TABLE -->
            <table style="width:100%; border-collapse:collapse; border:1px solid #000; border-top:none;">
                <thead>
                    <tr style="border-bottom:1px solid #000;">
                        <th style="width:6%; border-right:1px solid #000; padding:8px 4px; text-align:center;">SI<br/>
                            No.
                        </th>
                        <th style="width:54%; border-right:1px solid #000; padding:8px 8px; text-align:center;">
                            Particulars
                        </th>
                        <th style="width:10%; border-right:1px solid #000; padding:8px 4px; text-align:center;">
                            HSN/SAC
                        </th>
                        <th style="width:12%; border-right:1px solid #000; padding:8px 4px; text-align:center;">GST<br/>
                            Rate
                        </th>
                        <th style="width:18%; padding:8px 8px; text-align:center;">Amount</th>
                    </tr>
                </thead>
                <tbody>
                    <!-- Renders exactly one row per invoice line - 3 lines = 3 rows, 5 lines = 5 rows -->
                    <tr t-foreach="product_lines" t-as="line">
                        <td style="text-align:center; border-right:1px solid #000; padding:8px 4px; vertical-align:top;">
                            <span t-out="line_index + 1"/>
                        </td>
                        <td style="border-right:1px solid #000; padding:8px 8px; vertical-align:top;">
                            <strong>
                                <span t-out="line.product_id.display_name or line.name or ''"/>
                            </strong>
                            <t t-if="line.name and line.name != line.product_id.display_name">
                                <br/>
                                <em>
                                    <span t-out="line.name"/>
                                </em>
                            </t>
                        </td>
                        <td style="text-align:center; border-right:1px solid #000; padding:8px 4px; vertical-align:top;">
                            <span t-out="line.product_id.l10n_in_hsn_code or ''"/>
                        </td>
                        <td style="text-align:center; border-right:1px solid #000; padding:8px 4px; vertical-align:top;">
                            <span t-out="sum(line.tax_ids.mapped('amount')) if line.tax_ids else 0"/>
                            %
                        </td>
                        <td style="text-align:right; padding:8px 8px; vertical-align:top;">
                            <span t-out="line.price_subtotal"
                                  t-options='{"widget":"monetary","display_currency":o.currency_id}'/>
                        </td>
                    </tr>

                    <!-- Summary row -->
                    <tr style="border-top:1px solid #000; font-weight:bold;">
                        <td colspan="4" style="border-right:1px solid #000; padding:10px 8px; font-size:10px;">
                            <span style="margin-right:18px;">
                                <span t-out="tax_label"/>:
                                <span t-out="o.amount_untaxed"
                                      t-options='{"widget":"monetary","display_currency":o.currency_id}'/>
                            </span>
                            <span style="margin-right:18px;">
                                Round off:
                                <span t-out="round_off"
                                      t-options='{"widget":"monetary","display_currency":o.currency_id}'/>
                            </span>
                            <span style="margin-right:18px;">
                                CGST:
                                <span t-out="abs(total_cgst)"
                                      t-options='{"widget":"monetary","display_currency":o.currency_id}'/>
                            </span>
                            <span style="margin-right:18px;">
                                SGST/UTGST:
                                <span t-out="abs(total_sgst)"
                                      t-options='{"widget":"monetary","display_currency":o.currency_id}'/>
                            </span>
                            <span style="float:right;">Total</span>
                        </td>
                        <td style="text-align:right; padding:10px 8px;">
                            <span t-out="o.amount_total"
                                  t-options='{"widget":"monetary","display_currency":o.currency_id}'/>
                        </td>
                    </tr>
                </tbody>
            </table>

            <!-- AMOUNT IN WORDS -->
            <div style="border:1px solid #000; border-top:none; padding:6px 8px; line-height:1.3;">
                Amount Chargeable (in words)<span style="float:right; font-size:10px; font-style:italic;">E. &amp; O.E</span><br/>
                <strong style="font-size:11px;"><t t-out="o.currency_id.amount_to_text(o.amount_total)"/></strong>
            </div>

            <!-- TAX SUMMARY TABLE -->
            <table style="width:100%; border-collapse:collapse; border:1px solid #000; border-top:none; font-size:10px;">
                <thead>
                    <tr style="border-bottom:1px solid #000;">
                        <th rowspan="2" style="border-right:1px solid #000; padding:6px 4px; text-align:center; vertical-align:middle;">HSN/SAC</th>
                        <th rowspan="2" style="border-right:1px solid #000; padding:6px 4px; text-align:center; vertical-align:middle;">Taxable<br/>Value</th>
                        <th colspan="2" style="border-right:1px solid #000; border-bottom:1px solid #000; padding:6px 4px; text-align:center;">CGST</th>
                        <th colspan="2" style="border-right:1px solid #000; border-bottom:1px solid #000; padding:6px 4px; text-align:center;">SGST/UTGST</th>
                        <th rowspan="2" style="padding:6px 4px; text-align:center; vertical-align:middle;">Total<br/>Tax Amount</th>
                    </tr>
                    <tr style="border-bottom:1px solid #000;">
                        <th style="border-right:1px solid #000; padding:4px; text-align:center;">Rate</th>
                        <th style="border-right:1px solid #000; padding:4px; text-align:center;">Amount</th>
                        <th style="border-right:1px solid #000; padding:4px; text-align:center;">Rate</th>
                        <th style="border-right:1px solid #000; padding:4px; text-align:center;">Amount</th>
                    </tr>
                </thead>
                <tbody>
                    <!-- Compute aggregates -->
                    <t t-set="taxed_lines" t-value="product_lines.filtered(lambda l: l.tax_ids)"/>
                    <t t-set="ts_taxable" t-value="sum(taxed_lines.mapped('price_subtotal'))"/>
                    <t t-set="ts_cgst_amt" t-value="abs(total_cgst)"/>
                    <t t-set="ts_sgst_amt" t-value="abs(total_sgst)"/>
                    <t t-set="ts_total_tax" t-value="ts_cgst_amt + ts_sgst_amt"/>
                    <t t-set="hsn_codes" t-value="list(set([l.product_id.l10n_in_hsn_code for l in taxed_lines if l.product_id.l10n_in_hsn_code]))"/>
                    <t t-set="first_line_full_rate" t-value="sum(taxed_lines[:1].tax_ids.mapped('amount')) if taxed_lines else 0"/>
                    <t t-set="ts_half_rate" t-value="first_line_full_rate / 2.0"/>

                    <!-- Data row -->
                    <tr>
                        <td style="border-right:1px solid #000; padding:6px 4px; text-align:center;">
                            <span t-out="', '.join(hsn_codes) if hsn_codes else ''"/>
                        </td>
                        <td style="border-right:1px solid #000; padding:6px 4px; text-align:right;">
                            <span t-out="ts_taxable" t-options='{"widget":"monetary","display_currency":o.currency_id}'/>
                        </td>
                        <td style="border-right:1px solid #000; padding:6px 4px; text-align:center;">
                            <t t-if="ts_half_rate"><span t-out="ts_half_rate"/>%</t>
                        </td>
                        <td style="border-right:1px solid #000; padding:6px 4px; text-align:right;">
                            <span t-out="ts_cgst_amt" t-options='{"widget":"monetary","display_currency":o.currency_id}'/>
                        </td>
                        <td style="border-right:1px solid #000; padding:6px 4px; text-align:center;">
                            <t t-if="ts_half_rate"><span t-out="ts_half_rate"/>%</t>
                        </td>
                        <td style="border-right:1px solid #000; padding:6px 4px; text-align:right;">
                            <span t-out="ts_sgst_amt" t-options='{"widget":"monetary","display_currency":o.currency_id}'/>
                        </td>
                        <td style="padding:6px 4px; text-align:right;">
                            <span t-out="ts_total_tax" t-options='{"widget":"monetary","display_currency":o.currency_id}'/>
                        </td>
                    </tr>

                    <!-- Total label row -->
                    <tr style="border-top:1px solid #000; font-weight:bold;">
                        <td style="border-right:1px solid #000; padding:6px 4px; text-align:right;">Total</td>
                        <td style="border-right:1px solid #000; padding:6px 4px; text-align:right;">
                            <span t-out="o.amount_untaxed" t-options='{"widget":"monetary","display_currency":o.currency_id}'/>
                        </td>
                        <td style="border-right:1px solid #000; padding:6px 4px;"></td>
                        <td style="border-right:1px solid #000; padding:6px 4px; text-align:right;">
                            <span t-out="abs(total_cgst)" t-options='{"widget":"monetary","display_currency":o.currency_id}'/>
                        </td>
                        <td style="border-right:1px solid #000; padding:6px 4px;"></td>
                        <td style="border-right:1px solid #000; padding:6px 4px; text-align:right;">
                            <span t-out="abs(total_sgst)" t-options='{"widget":"monetary","display_currency":o.currency_id}'/>
                        </td>
                        <td style="padding:6px 4px; text-align:right;">
                            <span t-out="o.amount_tax" t-options='{"widget":"monetary","display_currency":o.currency_id}'/>
                        </td>
                    </tr>
                </tbody>
            </table>

            <!-- TAX AMOUNT IN WORDS -->
            <div style="border:1px solid #000; border-top:none; padding:6px 8px; line-height:1.3;">
                Tax Amount (in words) :&#160;
                <strong><t t-out="o.currency_id.amount_to_text(o.amount_tax)"/></strong>
            </div>

            <!-- BOTTOM SECTION -->
            <table style="width:100%; border-collapse:collapse; border:1px solid #000; border-top:none;">
                <tr>
                    <td style="width:50%; vertical-align:top; border-right:1px solid #000; padding:10px 8px; font-size:10px;">
                        <strong>Company's PAN</strong>&#160;&#160;&#160;&#160;&#160;: <strong><t t-out="o.company_id.vat[2:12] if o.company_id.vat and len(o.company_id.vat) >= 12 else (o.company_id.vat or '')"/></strong><br/>
                        <strong>Declaration</strong><br/>
                        We declare that this invoice shows the price of the service described and that all particulars are true and correct.<br/>
                        Please note that the amount paid for booking/blocking for interiors will be a non refundable payment.
                    </td>
                    <td style="width:50%; vertical-align:top; padding:10px 8px; font-size:10px;">
                        <strong>Company's Bank Details</strong>
                        <table style="width:100%; border-collapse:separate; border-spacing:0; border:0; font-size:10px; margin-top:2px;">
                            <tr>
                                <td style="width:38%; padding:1px 0; border:0 !important;">A/c Holder's Name</td>
                                <td style="width:3%; padding:1px 0; border:0 !important;">:</td>
                                <td style="padding:1px 0; border:0 !important;">
                                    <strong><t t-out="bank_acc.partner_id.name if bank_acc else (o.partner_id.name or '')"/></strong>
                                </td>
                            </tr>
                            <tr>
                                <td style="padding:1px 0; border:0 !important;">Bank Name</td>
                                <td style="padding:1px 0; border:0 !important;">:</td>
                                <td style="padding:1px 0; border:0 !important;">
                                    <strong><t t-out="bank_acc.bank_id.name if bank_acc else ''"/></strong>
                                </td>
                            </tr>
                            <tr>
                                <td style="padding:1px 0; border:0 !important;">A/c No.</td>
                                <td style="padding:1px 0; border:0 !important;">:</td>
                                <td style="padding:1px 0; border:0 !important;">
                                    <strong><t t-out="bank_acc.acc_number if bank_acc else ''"/></strong>
                                </td>
                            </tr>
                            <tr>
                                <td style="padding:1px 0; border:0 !important;">Branch &amp; IFS Code</td>
                                <td style="padding:1px 0; border:0 !important;">:</td>
                                <td style="padding:1px 0; border:0 !important;">
                                    <strong>
                                        <t t-if="bank_acc">
                                            <t t-out="bank_acc.bank_id.city or ''"/> &amp; <t t-out="bank_acc.l10n_in_ifsc or ''"/>
                                        </t>
                                    </strong>
                                </td>
                            </tr>
                        </table>
                    </td>
                </tr>
                <tr style="border-top:1px solid #000;">
                    <td style="width:50%; vertical-align:top; border-right:1px solid #000; padding:8px 8px; font-size:10px; height:80px;">
                        Customer's Seal and Signature
                    </td>
                    <td style="width:50%; vertical-align:top; padding:8px 8px; font-size:10px; height:80px;">
                        <div style="text-align:right; font-size:10px; font-weight:bold;">
                            for <t t-out="o.company_id.name"/>
                        </div>
                        <div style="margin-top:45px; overflow:hidden;">
                            <div style="float:left; width:33%; text-align:left;">Prepared by</div>
                            <div style="float:left; width:34%; text-align:center;">Verified by</div>
                            <div style="float:right; width:33%; text-align:right;">Authorised Signatory</div>
                        </div>
                    </td>
                </tr>
            </table>
            <div style="text-align:center; margin-top:6px; font-size:11px;">
                <div style="font-weight:bold;">SUBJECT TO CHENNAI JURISDICTION</div>
                <div style="font-style:italic; margin-top:2px;">This is a Computer Generated Invoice</div>
            </div>
        </div>
    </template>

    <template id="report_invoice_tts">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <div class="article" t-att-data-oe-model="o._name" t-att-data-oe-id="o.id">
                    <t t-call="tts_purchase_order_report.report_invoice_document_tts"/>
                </div>
                <p t-if="not o_last" style="page-break-after:always;"/>
            </t>
        </t>
    </template>
</odoo>