<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- A4 landscape-friendly paper format with tight margins -->
    <record id="paperformat_tts_po" model="report.paperformat">
        <field name="name">TTS Purchase Order A4</field>
        <field name="default" eval="False"/>
        <field name="format">A4</field>
        <field name="page_height">0</field>
        <field name="page_width">0</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">8</field>
        <field name="margin_bottom">10</field>
        <field name="margin_left">5</field>
        <field name="margin_right">5</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">5</field>
        <field name="dpi">90</field>
    </record>

    <!-- Replace the default Purchase Order report with the TTS template -->
    <record id="purchase.action_report_purchase_order" model="ir.actions.report">
        <field name="report_name">tts_purchase_order_report.report_purchaseorder_tts</field>
        <field name="report_file">tts_purchase_order_report.report_purchaseorder_tts</field>
        <field name="paperformat_id" ref="paperformat_tts_po"/>
    </record>
</odoo>
