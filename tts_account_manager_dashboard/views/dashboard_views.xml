<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ───────────────────────────────────────────────────────────────
             Client action — registers the OWL dashboard component
        ─────────────────────────────────────────────────────────────────── -->
        <record id="action_account_manager_dashboard" model="ir.actions.client">
            <field name="name">Accounts Manager Dashboard</field>
            <field name="tag">tts_account_manager_dashboard.Dashboard</field>
            <field name="target">current</field>
        </record>

        <!-- ───────────────────────────────────────────────────────────────
             Top-level app entry  (only shown to account.group_account_manager)
             Associates see no menu at all — groups attribute enforces this.
        ─────────────────────────────────────────────────────────────────── -->
        <menuitem
            id="menu_account_manager_dashboard_root"
            name="Accounts Dashboard"
            sequence="3"
            groups="account.group_account_manager"
            web_icon="tts_account_manager_dashboard,static/description/icon.png"
        />

        <menuitem
            id="menu_account_manager_dashboard_home"
            name="Dashboard"
            parent="menu_account_manager_dashboard_root"
            action="action_account_manager_dashboard"
            sequence="10"
            groups="account.group_account_manager"
        />

        <!-- ───────────────────────────────────────────────────────────────
             Compatibility patch: remove is_exact_move_duplicate field refs
             from the standard account.move views.

             Some Odoo 19 builds ship view XML that references this field
             before the Python model defines it. Removing the node from the
             assembled view XML (server-side) means the client-side view
             compiler never encounters the missing field.

             Two separate inherit records cover both the list view and the
             form view.  Each xpath uses position="replace" with no content
             — this silently deletes the matched element.

             These overrides are no-ops once the core account module adds
             is_exact_move_duplicate to the model natively; the field will
             simply disappear from the view but nothing will break.
        ─────────────────────────────────────────────────────────────────── -->

        <!-- List view (account.view_move_tree) -->
        <record id="view_move_tree_rm_exact_duplicate" model="ir.ui.view">
            <field name="name">account.move.tree.rm.exact.duplicate.tts</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_tree"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='is_exact_move_duplicate']"
                       position="replace"/>
            </field>
        </record>

        <!-- Form view (account.view_move_form) -->
        <record id="view_move_form_rm_exact_duplicate" model="ir.ui.view">
            <field name="name">account.move.form.rm.exact.duplicate.tts</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='is_exact_move_duplicate']"
                       position="replace"/>
            </field>
        </record>

    </data>
</odoo>
