<odoo>
    <record id="view_margin_reject_wizard" model="ir.ui.view">
        <field name="name">margin.reject.wizard.form</field>
        <field name="model">margin.reject.wizard</field>
        <field name="arch" type="xml">
            <form string="Margin Rejection">
                <group>
                    <field name="remarks" placeholder="Enter rejection reason..."/>
                </group>
                <footer>
                    <button name="action_confirm_reject"
                            type="object"
                            string="Reject"
                            class="btn-danger"/>
                    <button string="Cancel" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>