<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_invoice_reject_wizard_form" model="ir.ui.view">
            <field name="name">invoice.reject.wizard.form</field>
            <field name="model">invoice.reject.wizard</field>
            <field name="arch" type="xml">
                <form string="Reject Invoice / Receipt">
                    <group>
                        <field name="reason" placeholder="Enter the reason for rejection…"
                               rows="4" nolabel="1"/>
                    </group>
                    <footer>
                        <button name="action_confirm_reject" type="object"
                                string="Confirm Rejection" class="btn-danger"/>
                        <button special="cancel" string="Cancel"/>
                    </footer>
                </form>
            </field>
        </record>

    </data>
</odoo>
