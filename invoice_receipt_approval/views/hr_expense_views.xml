<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="hr_expense_view_form_inherit_inv_receipt_approval" model="ir.ui.view">
            <field name="name">hr.expense.form.inherit.inv.receipt.approval</field>
            <field name="model">hr.expense</field>
            <field name="inherit_id" ref="hr_expense.hr_expense_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//header" position="inside">
                    <field name="inv_expense_is_account_manager" invisible="1"/>
                </xpath>
                <xpath expr="//button[@name='action_submit']" position="attributes">
                    <attribute name="groups">account.group_account_invoice</attribute>
                    <attribute name="invisible" add="inv_expense_is_account_manager" separator=" or "/>
                </xpath>
                <xpath expr="//button[@name='action_approve']" position="attributes">
                    <attribute name="groups">account.group_account_manager</attribute>
                </xpath>
                <xpath expr="//button[@name='action_refuse']" position="attributes">
                    <attribute name="groups">account.group_account_manager</attribute>
                </xpath>
            </field>
        </record>

        <record id="hr_expense_view_search_inherit_inv_receipt_approval" model="ir.ui.view">
            <field name="name">hr.expense.search.inherit.inv.receipt.approval</field>
            <field name="model">hr.expense</field>
            <field name="inherit_id" ref="hr_expense.hr_expense_view_search"/>
            <field name="arch" type="xml">
                <xpath expr="//filter[@name='submitted']" position="attributes">
                    <attribute name="groups">account.group_account_manager</attribute>
                </xpath>
            </field>
        </record>

    </data>
</odoo>
