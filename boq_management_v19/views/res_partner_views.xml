<?xml version="1.0" encoding="utf-8"?>
<odoo>

   
    <record id="view_res_partner_boq_v19" model="ir.ui.view">
        <field name="name">res.partner.form.boq.v19</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">

            <xpath expr="//div[@name='button_box']" position="inside">
                <button type="object"
                        name="action_view_boqs"
                        class="oe_stat_button"
                        icon="fa-calculator"
                        invisible="boq_count == 0">
                    <field name="boq_count" widget="statinfo" string="BOQs"/>
                </button>

                <!-- Avg rating button — navigates to rating list, shows X.X / 5 -->
                <button type="object"
                        name="action_view_ratings"
                        class="oe_stat_button"
                        icon="fa-star"
                        invisible="rating_count == 0">
                    <div class="o_stat_info">
                        <span class="o_stat_value">
                            <field name="avg_rating" widget="float" digits="[2,1]"/> / 5
                        </span>
                        <span class="o_stat_text">Avg Rating</span>
                    </div>
                </button>

                <!-- Rate button — always visible for vendor/supplier, opens dialog -->
                <button type="object"
                        name="action_rate_vendor"
                        class="oe_stat_button"
                        icon="fa-star-o"
                        invisible="partner_type not in ('vendor', 'supplier')">
                    <div class="o_stat_info">
                        <span class="o_stat_value">Rate</span>
                        <span class="o_stat_text">Vendor</span>
                    </div>
                </button>
            </xpath>

             <xpath expr="//field[@name='company_type']" position="after">
                <label for="partner_type" string="Partner Type"/>
                <field name="partner_type"/>
            </xpath>
            <xpath expr="//field[@name='email']" position="attributes">
                <attribute name="required">1</attribute>
            </xpath>

            <xpath expr="//notebook" position="inside">
                <page string="BOQ Configuration" name="boq_config">
                    <group string="BOQ Partner Settings">
                        <group>
                            <field name="partner_type" string="Partner Type"
                                   help="Vendor: material supply / trade execution. Supplier: procurement / main contractor. Employee: internal resource. Customer: BOQ client."/>
                            <field name="work_category_ids" widget="many2many_tags"
                                   string="Work Categories"
                                   help="Select the trades / work categories this partner handles. Used to auto-assign partners to RFQs based on BOQ category matching."/>
                        </group>
                    </group>
                </page>
            </xpath>

            <xpath expr="//notebook" position="inside">
                <!-- Tab always visible for vendor/supplier partners -->
                <page string="Vendor Ratings" name="vendor_ratings"
                      invisible="partner_type not in ('vendor', 'supplier')">
                    <group>
                        <group string="Rating Summary">
                            <field name="avg_rating" string="Average Rating" readonly="1"
                                   widget="float" digits="[2,1]"/>
                            <field name="rating_count" string="Total Ratings" readonly="1"/>
                        </group>
                        <group>
                            <button type="object"
                                    name="action_rate_vendor"
                                    string="Add Rating"
                                    class="btn btn-primary"
                                    icon="fa-star-o"/>
                            <button type="object"
                                    name="action_view_ratings"
                                    string="View All Ratings"
                                    class="btn btn-secondary"
                                    icon="fa-list"/>
                        </group>
                    </group>
                </page>
            </xpath>

        </field>
    </record>

</odoo>
