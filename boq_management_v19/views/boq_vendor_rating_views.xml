<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_boq_vendor_rating_form" model="ir.ui.view">
        <field name="name">boq.vendor.rating.form</field>
        <field name="model">boq.vendor.rating</field>
        <field name="arch" type="xml">
            <form string="Rate Vendor">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="partner_id" readonly="1" options="{'no_open': True}"/>
                        </h1>
                        <h2 class="text-muted">
                            <field name="purchase_order_id" readonly="1" options="{'no_open': True}"/>
                        </h2>
                    </div>
                    <group>
                        <group string="Rating">
                            <field name="rating" widget="radio"/>
                            <field name="date"/>
                        </group>
                        <group string="Order Details">
                            <field name="company_id" readonly="1"/>
                            <field name="partner_type" readonly="1"/>
                        </group>
                    </group>
                    <group string="Comments">
                        <field name="comments"
                               placeholder="Enter comments about vendor delivery, quality, communication…"
                               nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_boq_vendor_rating_list" model="ir.ui.view">
        <field name="name">boq.vendor.rating.list</field>
        <field name="model">boq.vendor.rating</field>
        <field name="arch" type="xml">
            <list string="Vendor Ratings" decoration-success="rating_int == 5"
                  decoration-info="rating_int == 4"
                  decoration-warning="rating_int == 2"
                  decoration-danger="rating_int == 1">
                <field name="date"/>
                <field name="partner_id"/>
                <field name="partner_type" optional="show"/>
                <field name="purchase_order_id"/>
                <field name="rating"/>
                <field name="rating_int" column_invisible="1"/>
                <field name="comments" optional="show"/>
                <field name="company_id" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="action_boq_vendor_rating" model="ir.actions.act_window">
        <field name="name">Vendor Ratings</field>
        <field name="res_model">boq.vendor.rating</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No vendor ratings yet!</p>
            <p>Ratings are created from the <b>Rate Vendor</b> button on a
               Purchase Order after the goods are received and the invoice is paid.</p>
        </field>
    </record>

</odoo>
