<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_boq_order_line_list" model="ir.ui.view">
        <field name="name">boq.order.line.list</field>
        <field name="model">boq.order.line</field>
        <field name="arch" type="xml">
            <list string="BOQ Lines"
                  decoration-info="product_type == 'labour'"
                  decoration-warning="product_type == 'equipment'"
                  decoration-danger="product_type == 'subcontract'">
                <field name="sequence" widget="handle"/>
                <field name="boq_id"/>
                <field name="category_id"/>
                <field name="product_id"/>
                <field name="product_name" optional="show"/>
                <field name="product_type" widget="badge"
                       decoration-success="product_type == 'material'"
                       decoration-info="product_type == 'labour'"
                       decoration-warning="product_type == 'equipment'"
                       decoration-danger="product_type == 'subcontract'"/>
                <field name="qty"/>
                <field name="uom_id" optional="show"/>
                <field name="unit_price" optional="show"/>
                <field name="tax_ids" string="Taxes" widget="many2many_tags" optional="show"/>
                <field name="cost_price" optional="hide"/>
                <field name="discount" optional="hide"/>
                <field name="subtotal" sum="Subtotal"/>
                <field name="tax_amount" string="Total Tax" readonly="1" optional="show" sum="Total Tax"/>
                <field name="total_value" string="Total Value" readonly="1" optional="show" sum="Total (incl. Tax)"/>
                <field name="margin_percent" column_invisible="True"/>
                <field name="currency_id" column_invisible="True"/>
                <field name="notes" optional="hide"/>
            </list>
        </field>
    </record>

</odoo>
