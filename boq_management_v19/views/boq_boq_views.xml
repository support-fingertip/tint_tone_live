<?xml version="1.0" encoding="utf-8"?>
<odoo>
<record id="view_boq_boq_form" model="ir.ui.view">
    <field name="name">boq.boq.form</field>
    <field name="model">boq.boq</field>
    <field name="arch" type="xml">
        <form string="Bill of Quantities" js_class="boq_form">

            <header>
                <button name="action_done"
                        string="Mark Done"
                        type="object"
                        class="btn-primary"
                        invisible="state != 'draft'"/>
                <button name="action_reset_draft"
                        string="Reset to Draft"
                        type="object"
                        class="btn-secondary"
                        invisible="state != 'done'"/>
               
                <button name="action_create_rfq"
                        string="Create RFQ"
                        type="object"
                        class="btn-primary"
                        icon="fa-shopping-cart"
                        invisible="line_count == 0"
                        confirm="This will create one RFQ per vendor / supplier based on the trade assignments below. Proceed?"/>
                <field name="state"
                       widget="statusbar"
                       statusbar_visible="draft,done"/>
            </header>

            <sheet>
                <div class="oe_button_box" name="button_box">
                    <button name="action_view_lines"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-list-ul">
                        <field name="line_count" widget="statinfo" string="Lines"/>
                    </button>
                    <button name="action_view_lines"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-money">
                        <div class="o_stat_info">
                            <span class="o_stat_value">
                                <field name="grand_total"
                                       widget="monetary"
                                       options="{'currency_field': 'currency_id'}"
                                       nolabel="1"/>
                            </span>
                            <span class="o_stat_text">Total</span>
                        </div>
                    </button>
                    <button name="action_view_rfqs"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-shopping-cart"
                            invisible="rfq_count == 0">
                        <field name="rfq_count" widget="statinfo" string="RFQs"/>
                    </button>
                </div>

                <field name="priority" widget="priority" class="float-start me-3 mt-1"/>

                <div class="oe_title">
                    <label for="name" string="BOQ Reference"/>
                    <h1>
                        <field name="name" readonly="1"/>
                    </h1>
                </div>

                <group>
                    <group string="Customer &amp; Project">
                        <field name="partner_id"
                               options="{'no_create_edit': True}"/>
                        <field name="partner_shipping_id"/>
                        <field name="project_id"
                               options="{'no_create_edit': True}"/>
                        <field name="project_name"/>
                        <field name="project_location"/>
                    </group>
                    <group string="Details">
                        <field name="date"/>
                        <field name="validity_date"/>
                        <field name="user_id" widget="many2one_avatar_user"
                               options="{'no_create_edit': True}"/>
                        <field name="company_id"
                               options="{'no_create': True}"
                               groups="base.group_multi_company"/>
                       
                        <field name="boq_type" widget="radio"/>
                    </group>
                </group>

                <group string="Work Categories">
                    <field name="category_ids"
                           widget="many2many_tags"
                           required="1"
                           options="{'color_field': 'color', 'no_create_edit': True}"
                           placeholder="Select work categories to activate their tabs…"
                           nolabel="1"/>
                </group>

                <group string="Vendor / Supplier Assignment">
                    <div class="text-muted small mb-2" colspan="2">
                        Rows appear automatically when Work Categories are selected above.
                        Set <b>Type</b> — Vendor shows the <b>Vendors</b> field,
                        Supplier shows the <b>Suppliers</b> field.
                        Each selected partner receives a separate RFQ with <em>all</em>
                        lines from that category.
                    </div>
                    <field name="trade_vendor_ids" nolabel="1" colspan="2" mode="list">
                        <list editable="bottom">
                            <field name="category_id" string="Work Category"
                                   options="{'no_create_edit': True}"/>
                            <field name="partner_type" string="Type"/>
                            <field name="vendor_ids"
                                   widget="many2many_tags"
                                   string="Vendors"
                                   domain="[('partner_type', '=', 'vendor')]"
                                   options="{'no_create_edit': True}"
                                   invisible="partner_type != 'vendor'"/>
                            <field name="supplier_ids"
                                   widget="many2many_tags"
                                   string="Suppliers"
                                   domain="[('partner_type', '=', 'supplier')]"
                                   options="{'no_create_edit': True}"
                                   invisible="partner_type != 'supplier'"/>
                            <field name="line_count" string="Lines" readonly="1"/>
                        </list>
                    </field>
                </group>
<notebook>
<page string="Electrical" name="tab_electrical"
                          invisible="not show_electrical">
                        <field name="electrical_line_ids"
                               context="{'default_category_id': electrical_category_id}"
                               mode="list">
                            <list editable="bottom">
                                <field name="sequence" widget="handle" string="#"/>
                                <field name="product_id" required="1" string="Product"
                                       options="{'no_create_edit': False}"/>
                                <field name="product_name" string="Description"/>
                                <field name="product_type" string="Type"/>
                                <field name="qty" string="Qty"/>
                                <field name="uom_id" string="Unit" optional="show"/>
                                <field name="unit_price" string="Unit Price"/>
                                <field name="tax_ids" string="Taxes"
                                       widget="many2many_tags"
                                       domain="[('type_tax_use','in',('purchase','all'))]"
                                       optional="show"/>
                                <field name="cost_price" string="Cost Price" optional="hide"/>
                                <field name="discount" string="Disc %" optional="hide"/>
                                <field name="subtotal" string="Subtotal"
                                       readonly="1" sum="Tab Total"/>
                                <field name="tax_amount" string="Total Tax"
                                       readonly="1" optional="show" sum="Total Tax"/>
                                <field name="total_value" string="Total Value"
                                       readonly="1" optional="show" sum="Total (incl. Tax)"/>
                                <field name="margin_percent" string="Margin %"
                                       readonly="1" optional="show"/>
                                <field name="currency_id" column_invisible="True"/>
                                <field name="notes" string="Notes" optional="hide"/>
                                <field name="category_id" column_invisible="True"
                                       required="1"/>
                            </list>
                        </field>
                    </page>
