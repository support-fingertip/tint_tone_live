<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <!-- Section label -->
        <record id="module_category_tint_tone_shade_rights" model="ir.module.category">
            <field name="name">TINT TONE and SHADE Rights</field>
            <field name="sequence">100</field>
        </record>

        <!-- One privilege per group = boolean checkbox rendering -->

        <record id="privilege_boq_user" model="res.groups.privilege">
            <field name="name">BOQ User</field>
            <field name="category_id" ref="module_category_tint_tone_shade_rights"/>
            <field name="sequence">10</field>
        </record>
        <record id="group_boq_user" model="res.groups">
            <field name="name">BOQ User</field>
            <field name="privilege_id" ref="privilege_boq_user"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="privilege_boq_manager" model="res.groups.privilege">
            <field name="name">BOQ Manager</field>
            <field name="category_id" ref="module_category_tint_tone_shade_rights"/>
            <field name="sequence">20</field>
        </record>
        <record id="group_boq_manager" model="res.groups">
            <field name="name">BOQ Manager</field>
            <field name="privilege_id" ref="privilege_boq_manager"/>
            <field name="implied_ids" eval="[(4, ref('group_boq_user'))]"/>
        </record>

        <record id="privilege_vendor" model="res.groups.privilege">
            <field name="name">Vendor</field>
            <field name="category_id" ref="module_category_tint_tone_shade_rights"/>
            <field name="sequence">30</field>
        </record>
        <record id="group_vendor" model="res.groups">
            <field name="name">Vendor</field>
            <field name="privilege_id" ref="privilege_vendor"/>
        </record>

        <record id="privilege_supplier" model="res.groups.privilege">
            <field name="name">Supplier</field>
            <field name="category_id" ref="module_category_tint_tone_shade_rights"/>
            <field name="sequence">40</field>
        </record>
        <record id="group_supplier" model="res.groups">
            <field name="name">Supplier</field>
            <field name="privilege_id" ref="privilege_supplier"/>
        </record>

        <record id="privilege_vendor_manager_dashboard" model="res.groups.privilege">
            <field name="name">Vendor Manager Dashboard</field>
            <field name="category_id" ref="module_category_tint_tone_shade_rights"/>
            <field name="sequence">50</field>
        </record>
        <record id="group_vendor_manager_dashboard" model="res.groups">
            <field name="name">Vendor Manager Dashboard</field>
            <field name="privilege_id" ref="privilege_vendor_manager_dashboard"/>
            <field name="implied_ids" eval="[(4, ref('group_boq_user'))]"/>
        </record>

        <record id="privilege_procurement_manager_dashboard" model="res.groups.privilege">
            <field name="name">Procurement Manager Dashboard</field>
            <field name="category_id" ref="module_category_tint_tone_shade_rights"/>
            <field name="sequence">60</field>
        </record>
        <record id="group_procurement_manager_dashboard" model="res.groups">
            <field name="name">Procurement Manager Dashboard</field>
            <field name="privilege_id" ref="privilege_procurement_manager_dashboard"/>
            <field name="implied_ids" eval="[(4, ref('group_boq_user'))]"/>
        </record>

        <record id="privilege_head_supplier_dashboard" model="res.groups.privilege">
            <field name="name">Head of Supplier Dashboard</field>
            <field name="category_id" ref="module_category_tint_tone_shade_rights"/>
            <field name="sequence">70</field>
        </record>
        <record id="group_head_supplier_dashboard" model="res.groups">
            <field name="name">Head of Supplier Dashboard</field>
            <field name="privilege_id" ref="privilege_head_supplier_dashboard"/>
            <field name="implied_ids" eval="[(4, ref('group_boq_manager'))]"/>
        </record>

    </data>
</odoo>