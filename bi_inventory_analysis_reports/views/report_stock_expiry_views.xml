<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ═══════════════════════════════════════════════════
         STOCK EXPIRY REPORT
    ═══════════════════════════════════════════════════ -->

    <!-- List View -->
    <record id="view_bi_stock_expiry_list" model="ir.ui.view">
        <field name="name">bi.stock.expiry.report.list</field>
        <field name="model">bi.stock.expiry.report</field>
        <field name="arch" type="xml">
            <list string="Stock Expiry Report" create="0" edit="0" delete="0" export_xlsx="1"
                  default_order="expiration_date asc">
                <field name="product_id" optional="show"/>
                <field name="categ_id" optional="show"/>
                <field name="lot_id" optional="show"/>
                <field name="location_id" optional="show"/>
                <field name="warehouse_id" optional="show"/>
                <field name="uom_id" optional="hide" string="UoM"/>
                <field name="qty_on_hand" optional="show" sum="Total Qty"/>
                <field name="expiration_date" optional="show"
                       decoration-danger="expiry_status=='expired'"
                       decoration-warning="expiry_status in ('near_expiry','expiring_soon')"/>
                <field name="best_before_date" optional="show"/>
                <field name="removal_date" optional="hide"/>
                <field name="days_to_expiry" optional="show"
                       decoration-danger="expiry_status=='expired'"
                       decoration-warning="expiry_status in ('near_expiry','expiring_soon')"
                       decoration-success="expiry_status=='ok'"/>
                <field name="expiry_status" optional="show"
                       decoration-danger="expiry_status=='expired'"
                       decoration-warning="expiry_status in ('near_expiry','expiring_soon')"
                       decoration-success="expiry_status=='ok'"
                       decoration-muted="expiry_status=='no_expiry'"/>
                <field name="cost_price" optional="show"/>
                <field name="currency_id" column_invisible="1"/>
                <field name="total_value" optional="show" sum="Total Value" widget="monetary"/>
                <field name="company_id" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- Pivot View -->
    <record id="view_bi_stock_expiry_pivot" model="ir.ui.view">
        <field name="name">bi.stock.expiry.report.pivot</field>
        <field name="model">bi.stock.expiry.report</field>
        <field name="arch" type="xml">
            <pivot string="Stock Expiry Report" disable_linking="True">
                <field name="expiry_status" type="col"/>
                <field name="categ_id" type="row"/>
                <field name="product_id" type="row"/>
                <field name="qty_on_hand" type="measure"/>
                <field name="total_value" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- Graph View -->
    <record id="view_bi_stock_expiry_graph" model="ir.ui.view">
        <field name="name">bi.stock.expiry.report.graph</field>
        <field name="model">bi.stock.expiry.report</field>
        <field name="arch" type="xml">
            <graph string="Stock Expiry Report" type="bar">
                <field name="expiry_status" type="row"/>
                <field name="qty_on_hand" type="measure"/>
                <field name="total_value" type="measure"/>
            </graph>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_bi_stock_expiry_search" model="ir.ui.view">
        <field name="name">bi.stock.expiry.report.search</field>
        <field name="model">bi.stock.expiry.report</field>
        <field name="arch" type="xml">
            <search string="Stock Expiry Report">
                <field name="product_id"/>
                <field name="categ_id"/>
                <field name="lot_id"/>
                <field name="location_id"/>
                <field name="warehouse_id"/>
                <field name="company_id" groups="base.group_multi_company"/>

                <!-- Expiry Status Filters -->
                <filter string="Expired" name="filter_expired"
                    domain="[('expiry_status','=','expired')]"/>
                <filter string="Near Expiry (≤ 30 days)" name="filter_near_expiry"
                    domain="[('expiry_status','=','near_expiry')]"/>
                <filter string="Expiring Soon (≤ 90 days)" name="filter_expiring_soon"
                    domain="[('expiry_status','=','expiring_soon')]"/>
                <filter string="OK" name="filter_ok"
                    domain="[('expiry_status','=','ok')]"/>
                <separator/>
                <filter string="Action Required" name="filter_action_required"
                    domain="[('expiry_status','in',['expired','near_expiry'])]"/>
                <filter string="Expiring within 90 Days" name="filter_expiring_90"
                    domain="[('expiry_status','in',['expired','near_expiry','expiring_soon'])]"/>
                <group>
                    <filter string="Expiry Status" name="group_status"
                        context="{'group_by': 'expiry_status'}"/>
                    <filter string="Product" name="group_product"
                        context="{'group_by': 'product_id'}"/>
                    <filter string="Product Category" name="group_categ"
                        context="{'group_by': 'categ_id'}"/>
                    <filter string="Lot / Serial" name="group_lot"
                        context="{'group_by': 'lot_id'}"/>
                    <filter string="Location" name="group_location"
                        context="{'group_by': 'location_id'}"/>
                    <filter string="Warehouse" name="group_warehouse"
                        context="{'group_by': 'warehouse_id'}"/>
                    <filter string="Company" name="group_company"
                        context="{'group_by': 'company_id'}"
                        groups="base.group_multi_company"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Window Action -->
    <record id="action_bi_stock_expiry_report" model="ir.actions.act_window">
        <field name="name">Stock Expiry Report</field>
        <field name="res_model">bi.stock.expiry.report</field>
        <field name="view_mode">list,pivot,graph</field>
        <field name="search_view_id" ref="view_bi_stock_expiry_search"/>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No lot-tracked stock found
            </p>
            <p>This report shows expiry status for all lot-tracked products. Requires the Product Expiry module and lot tracking to be enabled on products.</p>
        </field>
    </record>

</odoo>
