<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ═══════════════════════════════════════════════════
         INVENTORY AGING ANALYSIS
    ═══════════════════════════════════════════════════ -->

    <!-- List View -->
    <record id="view_bi_stock_aging_list" model="ir.ui.view">
        <field name="name">bi.stock.aging.report.list</field>
        <field name="model">bi.stock.aging.report</field>
        <field name="arch" type="xml">
            <list string="Inventory Aging Analysis" create="0" edit="0" delete="0" export_xlsx="1"
                  default_order="days_in_stock desc">
                <field name="product_id" optional="show"/>
                <field name="categ_id" optional="show"/>
                <field name="location_id" optional="show"/>
                <field name="warehouse_id" optional="show"/>
                <field name="lot_id" optional="show"/>
                <field name="uom_id" optional="hide" string="UoM"/>
                <field name="qty_on_hand" optional="show" sum="Total Qty"/>
                <field name="in_date" optional="show"/>
                <field name="days_in_stock" optional="show"
                       decoration-success="days_in_stock &lt;= 30"
                       decoration-warning="days_in_stock &gt; 30 and days_in_stock &lt;= 90"
                       decoration-danger="days_in_stock &gt; 90"/>
                <field name="aging_bucket" optional="show"/>
                <field name="cost_price" optional="show"/>
                <field name="currency_id" column_invisible="1"/>
                <field name="total_value" optional="show" sum="Total Value" widget="monetary"/>
                <field name="company_id" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- Pivot View -->
    <record id="view_bi_stock_aging_pivot" model="ir.ui.view">
        <field name="name">bi.stock.aging.report.pivot</field>
        <field name="model">bi.stock.aging.report</field>
        <field name="arch" type="xml">
            <pivot string="Inventory Aging Analysis" disable_linking="True">
                <field name="aging_bucket" type="col"/>
                <field name="categ_id" type="row"/>
                <field name="product_id" type="row"/>
                <field name="qty_on_hand" type="measure"/>
                <field name="total_value" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- Graph View -->
    <record id="view_bi_stock_aging_graph" model="ir.ui.view">
        <field name="name">bi.stock.aging.report.graph</field>
        <field name="model">bi.stock.aging.report</field>
        <field name="arch" type="xml">
            <graph string="Inventory Aging Analysis" type="bar">
                <field name="aging_bucket" type="row"/>
                <field name="qty_on_hand" type="measure"/>
                <field name="total_value" type="measure"/>
            </graph>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_bi_stock_aging_search" model="ir.ui.view">
        <field name="name">bi.stock.aging.report.search</field>
        <field name="model">bi.stock.aging.report</field>
        <field name="arch" type="xml">
            <search string="Inventory Aging Analysis">
                <field name="product_id"/>
                <field name="categ_id"/>
                <field name="location_id"/>
                <field name="warehouse_id"/>
                <field name="lot_id"/>
                <field name="company_id" groups="base.group_multi_company"/>

                <!-- Aging Bucket Filters -->
                <filter string="0–30 Days" name="filter_0_30"
                    domain="[('aging_bucket','=','0_30')]"/>
                <filter string="31–60 Days" name="filter_31_60"
                    domain="[('aging_bucket','=','31_60')]"/>
                <filter string="61–90 Days" name="filter_61_90"
                    domain="[('aging_bucket','=','61_90')]"/>
                <filter string="91–180 Days" name="filter_91_180"
                    domain="[('aging_bucket','=','91_180')]"/>
                <filter string="Over 180 Days" name="filter_over_180"
                    domain="[('aging_bucket','=','over_180')]"/>
                <separator/>
                <filter string="Aged Over 90 Days" name="filter_old"
                    domain="[('days_in_stock','&gt;',90)]"/>
                <filter string="Aged Over 180 Days" name="filter_very_old"
                    domain="[('days_in_stock','&gt;',180)]"/>

                <group>
                    <filter string="Aging Bucket" name="group_bucket"
                        context="{'group_by': 'aging_bucket'}"/>
                    <filter string="Product" name="group_product"
                        context="{'group_by': 'product_id'}"/>
                    <filter string="Product Category" name="group_categ"
                        context="{'group_by': 'categ_id'}"/>
                    <filter string="Location" name="group_location"
                        context="{'group_by': 'location_id'}"/>
                    <filter string="Warehouse" name="group_warehouse"
                        context="{'group_by': 'warehouse_id'}"/>
                    <filter string="Lot / Serial" name="group_lot"
                        context="{'group_by': 'lot_id'}"/>
                    <filter string="Company" name="group_company"
                        context="{'group_by': 'company_id'}"
                        groups="base.group_multi_company"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Window Action -->
    <record id="action_bi_stock_aging_report" model="ir.actions.act_window">
        <field name="name">Inventory Aging Analysis</field>
        <field name="res_model">bi.stock.aging.report</field>
        <field name="view_mode">list,pivot,graph</field>
        <field name="search_view_id" ref="view_bi_stock_aging_search"/>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No aging data found
            </p>
            <p>This report shows how long current stock has been sitting in each location, bucketed by age range.</p>
        </field>
    </record>

</odoo>
