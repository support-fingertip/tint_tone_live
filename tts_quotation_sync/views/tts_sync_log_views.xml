<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ══════════════════════════════════════════════
         SYNC LOG LIST
    ══════════════════════════════════════════════ -->
    <record id="view_tts_sync_log_list" model="ir.ui.view">
        <field name="name">tts.sync.log.list</field>
        <field name="model">tts.sync.log</field>
        <field name="arch" type="xml">
            <list string="Sync Logs"
                  decoration-success="state == 'success'"
                  decoration-warning="state == 'partial'"
                  decoration-danger="state == 'error'">
                <field name="sync_date"/>
                <field name="quotations_fetched" string="Fetched"/>
                <field name="quotations_success" string="Success"/>
                <field name="quotations_failed" string="Failed"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'success'"
                       decoration-warning="state == 'partial'"
                       decoration-danger="state == 'error'"/>
                <field name="error_message" optional="show"/>
            </list>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════
         SYNC LOG FORM
    ══════════════════════════════════════════════ -->
    <record id="view_tts_sync_log_form" model="ir.ui.view">
        <field name="name">tts.sync.log.form</field>
        <field name="model">tts.sync.log</field>
        <field name="arch" type="xml">
            <form string="Sync Log" create="false" edit="false">
                <sheet>
                    <group>
                        <group string="Run Summary">
                            <field name="sync_date" readonly="1"/>
                            <field name="state" readonly="1" widget="badge"
                                   decoration-success="state == 'success'"
                                   decoration-warning="state == 'partial'"
                                   decoration-danger="state == 'error'"/>
                            <field name="quotations_fetched" readonly="1"/>
                            <field name="quotations_success" readonly="1"/>
                            <field name="quotations_failed" readonly="1"/>
                        </group>
                    </group>
                    <group invisible="not error_message">
                        <field name="error_message" readonly="1" widget="text"
                               string="Fatal Error"/>
                    </group>
                    <notebook>
                        <page string="Quotation Details" name="details">
                            <field name="log_line_ids" readonly="1">
                                <list create="0" delete="0">
                                    <field name="quotation_ext_id" string="Quotation ID"/>
                                    <field name="tts_quotation_id" string="Odoo Record"/>
                                    <field name="state" widget="badge"
                                           decoration-success="state == 'success'"
                                           decoration-danger="state == 'failure'"/>
                                    <field name="error_message"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════
         ACTION
    ══════════════════════════════════════════════ -->
    <record id="action_tts_sync_log" model="ir.actions.act_window">
        <field name="name">Sync Logs</field>
        <field name="res_model">tts.sync.log</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No sync runs recorded yet.
            </p>
            <p>
                Logs appear here every time the scheduled sync runs
                or you click <b>Sync Now</b>.
            </p>
        </field>
    </record>

</odoo>
