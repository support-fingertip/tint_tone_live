<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_res_config_settings_purchase" model="ir.ui.view">
        <field name="name">res.config.settings.view.purchase.inherit</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <div class="app_settings_block" data-string="Purchase Settings" string="Purchase Settings">
                    <h2>Purchase Advance Payment Product</h2>
                    <div class="row mt16 o_settings_container">
                        <!-- Advance Payment Product -->
                        <div class="col-12 col-lg-8 o_setting_box">
                            <group>
                                    <field name="purchase_advance_product_id" widget="many2one"/>
                            </group>
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
