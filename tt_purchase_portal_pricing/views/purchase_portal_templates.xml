<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="purchase_order_portal_content_inherit"
              name="Show Pricing on RFQ Portal"
              inherit_id="purchase.purchase_order_portal_content">

        <!-- Override: show price columns for all states, not just confirmed PO -->
        <xpath expr="//table[@id='purchase_order_table']//t[@t-set='display_price_and_taxes']" position="replace">
            <t t-set="display_price_and_taxes" t-value="not update_dates"/>
        </xpath>

        <!-- Override: make Unit Price editable on RFQ, read-only on PO -->
        <xpath expr="//div[@t-field='line.price_unit']/.." position="replace">
            <td t-if="display_price_and_taxes" t-attf-class="text-end #{'d-none d-sm-table-cell' if report_type == 'html' else ''}">
                <t t-if="order.state in ('draft', 'sent')">
                    <input type="number"
                        class="form-control form-control-sm text-end o_purchase_portal_price_input"
                        t-att-data-line-id="line.id"
                        t-att-value="line.price_unit"
                        step="0.01"
                        min="0"
                        style="width: 120px; display: inline-block;"/>
                </t>
                <t t-else="">
                    <div t-field="line.price_unit" class="text-end"/>
                </t>
            </td>
        </xpath>

        <!-- Override: show subtotal column for all states -->
        <xpath expr="//span[hasclass('oe_order_line_price_subtotal')]/.." position="replace">
            <td class="text-end" t-if="display_price_and_taxes">
                <span class="oe_order_line_price_subtotal" t-field="line.price_subtotal"/>
            </td>
        </xpath>

        <!-- Override: show section subtotals for all states -->
        <xpath expr="//tr[hasclass('is-subtotal')]/.." position="replace">
            <t t-if="current_section and (line_last or order.order_line[line_index+1].display_type in ('line_section', 'line_subsection'))">
                <tr class="is-subtotal text-end">
                    <td colspan="99">
                        <strong class="mr16">Subtotal</strong>
                        <span
                            t-esc="current_subtotal"
                            t-options='{"widget": "monetary", "display_currency": order.currency_id}'
                        />
                    </td>
                </tr>
            </t>
        </xpath>

        <!-- Override: show totals div for all states -->
        <xpath expr="//div[@id='total']" position="attributes">
            <attribute name="t-if">1</attribute>
        </xpath>

        <!-- Override: show totals div for all states -->
        <xpath expr="//div[@id='total']" position="attributes">
            <attribute name="t-if">1</attribute>
        </xpath>


    </template>

</odoo>
