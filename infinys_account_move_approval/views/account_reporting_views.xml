<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- My Approvals action for account moves -->
        <record id="action_account_move_my_approval" model="ir.actions.act_window">
            <field name="name">My Approvals</field>
            <field name="res_model">account.move</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[
                '|',
                    '&amp;',
                        '&amp;',
                            ('approval_state', '=', 'pending'),
                            ('approval_line_ids.status', '=', 'current'),
                        ('approval_line_ids.user_ids', 'in', [uid]),
                    '|',
                        ('approval_line_ids.approved_by_user_id', '=', uid),
                        ('approval_line_ids.rejected_by_user_id', '=', uid)
            ]</field>
            <field name="context">{'create': false, 'search_default_my_pending_approvals': 1}</field>
            <field name="target">current</field>
        </record>

        <!-- Add approval filters to account.move search view -->
        <record id="view_account_move_filter_inherit_approval" model="ir.ui.view">
            <field name="name">account.move.select.inherit.approval</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_account_move_filter"/>
            <field name="arch" type="xml">
                <xpath expr="//filter[@name='posted']" position="after">
                    <separator/>
                    <filter string="Pending My Approval" name="my_pending_approvals"
                            domain="[('approval_state', '=', 'pending'),
                                     ('approval_line_ids.status', '=', 'current'),
                                     ('approval_line_ids.user_ids', 'in', [uid])]"/>
                    <filter string="My Approval History" name="my_approval_history"
                            domain="['|',
                                     ('approval_line_ids.approved_by_user_id', '=', uid),
                                     ('approval_line_ids.rejected_by_user_id', '=', uid)]"/>
                </xpath>
            </field>
        </record>

        <!-- Menu item under Accounting > Reporting -->
        <menuitem
            id="menu_account_my_approval"
            name="My Approvals"
            parent="account.menu_finance_reports"
            action="action_account_move_my_approval"
            sequence="100"/>

    </data>
</odoo>
