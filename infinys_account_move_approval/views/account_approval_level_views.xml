<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_account_approval_level_list" model="ir.ui.view">
            <field name="name">account.approval.level.list</field>
            <field name="model">account.approval.level</field>
            <field name="arch" type="xml">
                <list string="Account Approval Levels">
                    <field name="name"/>
                    <field name="user_ids" widget="many2many_tags"/>
                    <field name="minimum_amount"/>
                    <field name="maximum_amount"/>
                    <field name="sequence"/>
                </list>
            </field>
        </record>

        <record id="view_account_approval_level_form" model="ir.ui.view">
            <field name="name">account.approval.level.form</field>
            <field name="model">account.approval.level</field>
            <field name="arch" type="xml">
                <form string="Account Approval Level">
                    <sheet>
                        <group string="Approval Level Details">
                            <group>
                                <field name="name"/>
                                <field name="minimum_amount"/>
                                <field name="maximum_amount"/>
                            </group>
                            <group>
                                <field name="sequence"/>
                                <field name="user_ids" widget="many2many_tags"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_account_approval_level" model="ir.actions.act_window">
            <field name="name">Account Approval Levels</field>
            <field name="res_model">account.approval.level</field>
            <field name="view_mode">list,form</field>
        </record>

        <menuitem
            id="menu_account_approval_level"
            name="Approval Levels"
            parent="account.account_account_menu"
            action="action_account_approval_level"
            sequence="100"/>

    </data>
</odoo>
