<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Inherit the account.move form view to add approval workflow -->
        <record id="view_move_form_inherit_approval" model="ir.ui.view">
            <field name="name">account.move.form.inherit.approval</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form"/>
            <field name="arch" type="xml">

                <!-- Add computed fields (invisible) for visibility conditions -->
                <xpath expr="//form/header/field[@name='state']" position="before">
                    <field name="approval_state" invisible="1"/>
                    <field name="is_admin" invisible="1"/>
                </xpath>

                <!-- Show approval status banners -->
                <xpath expr="//div[hasclass('oe_title')]" position="before">
                    <div class="alert alert-warning text-center"
                         role="alert"
                         invisible="approval_state != 'pending'">
                        <strong>This entry is pending approval.</strong>
                        Please check the Approval Details tab.
                    </div>
                    <div class="alert alert-danger text-center"
                         role="alert"
                         invisible="approval_state != 'rejected'">
                        <strong>This entry has been rejected.</strong>
                        Reset to draft to re-submit for approval.
                    </div>
                    <div class="alert alert-success text-center"
                         role="alert"
                         invisible="approval_state != 'approved'">
                        <strong>All approvals completed.</strong>
                        This entry is ready to be posted.
                    </div>
                </xpath>

                <!-- Add Approval Details tab in the notebook -->
                <xpath expr="//page[@name='other_info']" position="after">
                    <page string="Approval Details" name="approval_details"
                          invisible="not approval_line_ids">
                        <field name="approval_line_ids" widget="one2many_list" readonly="1">
                            <list>
                                <field name="level_id"/>
                                <field name="user_ids" widget="many2many_tags"/>
                                <field name="status"/>
                                <field name="approved_by_user_id"/>
                                <field name="rejected_by_user_id"/>
                                <field name="is_current_approver" column_invisible="1"/>
                                <button name="action_approve" type="object"
                                        string="Approve" class="btn btn-primary"
                                        invisible="not is_current_approver"/>
                                <button name="action_reject" type="object"
                                        string="Reject" class="btn btn-secondary"
                                        invisible="not is_current_approver"/>
                            </list>
                        </field>
                    </page>
                </xpath>

            </field>
        </record>

        <!-- Inherit the account.move list view to show approval state -->
        <record id="view_move_tree_inherit_approval" model="ir.ui.view">
            <field name="name">account.move.tree.inherit.approval</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_tree"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='state']" position="after">
                    <field name="approval_state" widget="badge" optional="show"
                           decoration-warning="approval_state == 'pending'"
                           decoration-success="approval_state == 'approved'"
                           decoration-danger="approval_state == 'rejected'"/>
                </xpath>
            </field>
        </record>

    </data>
</odoo>
