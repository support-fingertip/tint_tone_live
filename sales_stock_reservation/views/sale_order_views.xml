<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_order_form_inherit_reservation" model="ir.ui.view">
        <field name="name">sale.order.view.form.inherit.sales.stock.reservation</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">

            <!-- Apply stock reservation toggle next to Payment Terms -->
            <xpath expr="//field[@name='payment_term_id']" position="after">
                <field name="apply_stock_reservation"/>
                <field name="state_reservation" invisible="1"/>
            </xpath>

            <!-- Header buttons: visible only after the toggle is on -->
            <xpath expr="//button[@name='action_cancel']" position="after">
                <button name="action_create_stock_reservation"
                        string="Create Stock Reservation"
                        class="btn-primary"
                        type="object"
                        invisible="not apply_stock_reservation
                                   or state_reservation == 'reserved'
                                   or state not in ('draft','sent')"/>
                <button name="action_cancel_reservation"
                        string="Cancel Stock Reservation"
                        class="btn-secondary"
                        type="object"
                        invisible="not apply_stock_reservation
                                   or state_reservation != 'reserved'
                                   or state not in ('draft','sent')"/>
            </xpath>

            <!-- Reserved Stock tab -->
            <xpath expr="//page[@name='order_lines']" position="after">
                <page string="Reserved Stock"
                      name="reserved_stock"
                      invisible="not apply_stock_reservation">
                    <field name="reserved_ids" readonly="1">
                        <list>
                            <field name="name"/>
                            <field name="sale_order_line_id"/>
                            <field name="product_id"/>
                            <field name="reserved_quantity"/>
                            <field name="product_uom_id"/>
                            <field name="consumed_in_mo_id"/>
                            <field name="state"
                                   decoration-success="state == 'reserved'"
                                   decoration-info="state == 'consumed'"
                                   decoration-danger="state == 'cancel'"
                                   widget="badge"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
